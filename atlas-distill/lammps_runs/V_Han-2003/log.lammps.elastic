  using lattice units in orthogonal box = (0 0 0) to (15.15 15.15 15.15)
  create_atoms CPU = 0.000 seconds
mass 1 1.0

# ── Potential ──
pair_style eam/fs
pair_coeff * * V.eam.fs V

# ── Variables ──
variable delta equal 0.000001
variable len0 equal lx

