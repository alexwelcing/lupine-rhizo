units metal
boundary p p p
atom_style atomic

# ── Crystal Setup ──
lattice fcc 4.08006654573515
Lattice spacing in x,y,z = 4.0800665 4.0800665 4.0800665
region box block 0 5 0 5 0 5
create_box 1 box
