  using lattice units in orthogonal box = (0 0 0) to (20.400333 20.400333 20.400333)
  create_atoms CPU = 0.000 seconds
mass 1 1.0

# ── Potential ──
pair_style eam/alloy
pair_coeff * * Au.set Au

# ── Variables ──
variable delta equal 0.000001
variable len0 equal lx

