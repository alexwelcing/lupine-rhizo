  using lattice units in orthogonal box = (0 0 0) to (20.449999 20.449999 20.449999)
  create_atoms CPU = 0.000 seconds
mass 1 1.0

# ── Potential ──
pair_style eam
pair_coeff * * agu6.txt

# ── Variables ──
variable delta equal 0.000001
variable len0 equal lx

