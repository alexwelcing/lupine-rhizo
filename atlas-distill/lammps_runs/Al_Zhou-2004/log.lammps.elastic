units metal
boundary p p p
atom_style atomic

# ── Crystal Setup ──
lattice fcc 4.05018069032533
Lattice spacing in x,y,z = 4.0501807 4.0501807 4.0501807
region box block 0 5 0 5 0 5
create_box 1 box
