units metal
boundary p p p
atom_style atomic

# ── Crystal Setup ──
lattice fcc 4.02484538561055
Lattice spacing in x,y,z = 4.0248454 4.0248454 4.0248454
region box block 0 5 0 5 0 5
create_box 1 box
