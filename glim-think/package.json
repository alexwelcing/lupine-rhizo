{
  "name": "glim-think",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "gen:prompts": "node scripts/gen-prompts.mjs",
    "deploy": "node scripts/gen-prompts.mjs && wrangler deploy",
    "types": "wrangler types",
    "lint": "npm run lint:fast",
    "lint:fast": "node scripts/typecheck-core.mjs && node scripts/syntax-check.mjs src/server.ts",
    "lint:app": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc -p tsconfig.app.json --noEmit --pretty false",
    "lint:full": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc --noEmit --pretty false --extendedDiagnostics",
    "lint:profile": "node scripts/lint-profile.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai": "^3.0.64",
    "@ai-sdk/openai-compatible": "^2.0.45",
    "@arizeai/openinference-semantic-conventions": "^2.3.0",
    "@arizeai/openinference-vercel": "^2.7.5",
    "@cloudflare/shell": "^0.3.3",
    "@cloudflare/think": "^0.4.0",
    "@microlabs/otel-cf-workers": "^1.0.0-rc.52",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.200.0",
    "@opentelemetry/otlp-transformer": "^0.200.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "agents": "^0.11.5",
    "ai": "^6.0.168",
    "workers-ai-provider": "^3.1.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "@vitest/coverage-v8": "^4.1.6",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.0.0"
  }
}
